{
  "$id": "https://schemas.auditcore.dev/v1/risk_score.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "asset_importance": {
      "maximum": 5,
      "minimum": 1,
      "title": "Asset Importance",
      "type": "integer"
    },
    "blast_radius": {
      "maximum": 10,
      "minimum": 0,
      "title": "Blast Radius",
      "type": "integer"
    },
    "business_impact": {
      "maximum": 10,
      "minimum": 0,
      "title": "Business Impact",
      "type": "integer"
    },
    "composite": {
      "maximum": 100.0,
      "minimum": 0.0,
      "title": "Composite",
      "type": "number"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "exploitability": {
      "maximum": 10,
      "minimum": 0,
      "title": "Exploitability",
      "type": "integer"
    },
    "exposure": {
      "maximum": 10,
      "minimum": 0,
      "title": "Exposure",
      "type": "integer"
    },
    "finding_id": {
      "format": "uuid",
      "title": "Finding Id",
      "type": "string"
    },
    "fix_difficulty": {
      "maximum": 5,
      "minimum": 1,
      "title": "Fix Difficulty",
      "type": "integer"
    },
    "rank": {
      "minimum": 1,
      "title": "Rank",
      "type": "integer"
    },
    "rationale": {
      "title": "Rationale",
      "type": "string"
    },
    "scored_by_agent": {
      "title": "Scored By Agent",
      "type": "string"
    }
  },
  "required": [
    "finding_id",
    "exposure",
    "exploitability",
    "asset_importance",
    "blast_radius",
    "business_impact",
    "fix_difficulty",
    "confidence",
    "composite",
    "rank",
    "rationale",
    "scored_by_agent"
  ],
  "title": "RiskScore",
  "type": "object"
}
