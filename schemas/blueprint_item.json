{
  "$defs": {
    "Domain": {
      "enum": [
        "security",
        "performance",
        "cloud",
        "k8s",
        "db",
        "hardware"
      ],
      "title": "Domain",
      "type": "string"
    }
  },
  "$id": "https://schemas.auditcore.dev/v1/blueprint_item.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "applies_to_assets": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Applies To Assets",
      "type": "array"
    },
    "artifact_ref": {
      "title": "Artifact Ref",
      "type": "string"
    },
    "domain": {
      "$ref": "#/$defs/Domain"
    },
    "format": {
      "enum": [
        "terraform",
        "helm",
        "kustomize",
        "ansible",
        "sql",
        "markdown",
        "yaml"
      ],
      "title": "Format",
      "type": "string"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "idempotent": {
      "default": true,
      "title": "Idempotent",
      "type": "boolean"
    },
    "review_required": {
      "default": true,
      "title": "Review Required",
      "type": "boolean"
    },
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "sources": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Sources",
      "type": "array"
    },
    "target": {
      "title": "Target",
      "type": "string"
    }
  },
  "required": [
    "id",
    "run_id",
    "domain",
    "target",
    "format",
    "artifact_ref",
    "sources",
    "applies_to_assets"
  ],
  "title": "BlueprintItem",
  "type": "object"
}
