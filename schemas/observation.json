{
  "$defs": {
    "Domain": {
      "description": "Discovery domains. These name *what kind of system functionality* an\nobservation describes \u2014 not a risk category.",
      "enum": [
        "security",
        "performance",
        "cloud",
        "k8s",
        "db",
        "hardware",
        "network",
        "software"
      ],
      "title": "Domain",
      "type": "string"
    }
  },
  "$id": "https://schemas.auditcore.dev/v1/observation.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A precise, factual statement about discovered system functionality.\n\nObservations are descriptive, not evaluative: they record *what exists and\nhow it works*, in exhaustive detail, every claim backed by evidence. There\nis deliberately no severity, score, or recommendation \u2014 AuditCore reports\nfacts, it does not judge or prescribe.",
  "properties": {
    "asset_id": {
      "format": "uuid",
      "title": "Asset Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "detail": {
      "title": "Detail",
      "type": "string"
    },
    "domain": {
      "$ref": "#/$defs/Domain"
    },
    "evidence_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Evidence Ids",
      "type": "array"
    },
    "facts": {
      "additionalProperties": true,
      "title": "Facts",
      "type": "object"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "model_used": {
      "title": "Model Used",
      "type": "string"
    },
    "produced_by_agent": {
      "title": "Produced By Agent",
      "type": "string"
    },
    "related_asset_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Related Asset Ids",
      "type": "array"
    },
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "tenant_id": {
      "format": "uuid",
      "title": "Tenant Id",
      "type": "string"
    },
    "topic": {
      "title": "Topic",
      "type": "string"
    }
  },
  "required": [
    "id",
    "tenant_id",
    "run_id",
    "asset_id",
    "domain",
    "topic",
    "summary",
    "detail",
    "evidence_ids",
    "produced_by_agent",
    "model_used",
    "created_at"
  ],
  "title": "Observation",
  "type": "object"
}
