{% extends "_base.html.j2" %}
{% block title %}AuditCore Engineer Report — run {{ data.run.id }}{% endblock %}
{% block body %}
<h1>AuditCore Engineer Report</h1>
<p class="meta">Run <code>{{ data.run.id }}</code> · status <strong>{{ data.run.status }}</strong>
   · started {{ data.run.started_at }}
   {% if data.run.completed_at %}· completed {{ data.run.completed_at }}{% endif %}</p>

<h2>Severity summary</h2>
<div class="summary-bar">
  <div class="crit"><div><strong>{{ severity_counts.critical }}</strong></div><div>critical</div></div>
  <div class="high"><div><strong>{{ severity_counts.high }}</strong></div><div>high</div></div>
  <div class="med"><div><strong>{{ severity_counts.medium }}</strong></div><div>medium</div></div>
  <div class="low"><div><strong>{{ severity_counts.low }}</strong></div><div>low</div></div>
  <div class="info"><div><strong>{{ severity_counts.info }}</strong></div><div>info</div></div>
</div>

<h2>Assets ({{ data.assets|length }})</h2>
{% if data.assets %}
<table>
  <thead><tr><th>Name</th><th>Type</th><th>Natural key</th><th>Notable attributes</th></tr></thead>
  <tbody>
    {% for a in data.assets %}
    <tr>
      <td>{{ a.name }}</td>
      <td>{{ a.type }}</td>
      <td><code>{{ a.natural_key }}</code></td>
      <td>
        {% for k, v in (a.attributes or {}).items() if v is not none and k in ['cpu_model','os','os_release','kernel_release','architecture','machine_model','total_storage_bytes','numa_nodes','pci_gpus'] %}
          <div><span class="meta">{{ k }}:</span> {{ v }}</div>
        {% endfor %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="meta">No assets discovered.</p>
{% endif %}

<h2>Findings ({{ data.findings|length }})</h2>
{% if data.findings %}
{% for f in data.findings %}
<h3><span class="sev sev-{{ f.severity }}">{{ f.severity }}</span> {{ f.title }}</h3>
<p class="meta">{{ f.domain }} · asset <code>{{ f.asset_id }}</code> · agent {{ f.produced_by_agent }}</p>
<div>{{ f.description | md | safe }}</div>
<p class="meta">
  evidence:
  {% for eid in f.evidence_ids %}<span class="ref">{{ eid }}</span>{% if not loop.last %}, {% endif %}{% endfor %}
  {% if f.cve %} · CVE: {{ f.cve | join(', ') }}{% endif %}
  {% if f.cwe %} · CWE: {{ f.cwe | join(', ') }}{% endif %}
</p>
{% endfor %}
{% else %}
<p class="meta">No findings recorded — agents have not run yet, or this is a pure-inventory run.</p>
{% endif %}

<h2>Evidence ({{ data.evidence|length }})</h2>
<table>
  <thead><tr><th>Tool</th><th>Version</th><th>Category</th><th>Confidence</th><th>Severity hint</th><th>Collected at</th></tr></thead>
  <tbody>
    {% for e in data.evidence %}
    <tr>
      <td><code>{{ e.source_tool }}</code></td>
      <td>{{ e.source_tool_version }}</td>
      <td>{{ e.category }}</td>
      <td>{{ '%.2f' | format(e.confidence) }}</td>
      <td>{% if e.severity_hint %}<span class="sev sev-{{ e.severity_hint }}">{{ e.severity_hint }}</span>{% endif %}</td>
      <td class="meta">{{ e.collected_at }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<h2>Methodology</h2>
<p>This report was rendered directly from normalized data with no AI narrative.
Each finding cites at least one evidence item (a database-enforced invariant).
Re-render at any time:</p>
<pre>auditcore-report render {{ data.run.id }} --audience engineer --out report.html</pre>
{% endblock %}
