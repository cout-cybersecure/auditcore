<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{% block title %}AuditCore Report{% endblock %}</title>
  <style>
    body { font-family: -apple-system, "Segoe UI", system-ui, sans-serif;
           max-width: 1000px; margin: 2rem auto; padding: 0 1rem;
           color: #1a1a1a; line-height: 1.5; }
    h1, h2, h3 { margin-top: 2.2rem; }
    h1 { border-bottom: 2px solid #333; padding-bottom: .35rem; }
    h2 { border-bottom: 1px solid #ccc; padding-bottom: .25rem; }
    h3 { margin-bottom: .3rem; }
    table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
    th, td { border: 1px solid #d0d0d0; padding: .45rem .6rem; text-align: left; vertical-align: top; }
    th { background: #f4f4f4; }
    code, pre { font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
                background: #f5f5f5; padding: 1px 4px; border-radius: 3px; }
    pre { padding: .75rem; overflow-x: auto; }
    .domain-tag { display: inline-block; padding: 1px 8px; border-radius: 3px;
                  font-size: .8rem; font-weight: 600; color: #fff; background: #345; }
    .meta { color: #666; font-size: .9rem; }
    .obs { border-left: 3px solid #345; padding-left: .8rem; margin: 1.2rem 0; }
    .obs .summary { font-weight: 600; }
    .facts { margin: .4rem 0; }
    .facts code { display: inline-block; margin: 1px 2px; }
    .ref { color: #666; font-family: ui-monospace, monospace; font-size: .8rem; }
    .count-bar { display: flex; gap: .5rem; margin: 1rem 0; flex-wrap: wrap; }
    .count-bar > div { padding: .5rem .9rem; border-radius: 4px;
                       background: #eef2f6; min-width: 5rem; text-align: center; }
  </style>
</head>
<body>
  {% block body %}{% endblock %}
  <hr>
  <p class="meta">Generated by AuditCore report-generator at {{ generated_at }}.
  Descriptive renderer — facts only, no AI narrative, no assessment.</p>
</body>
</html>
