<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{% block title %}AuditCore Report{% endblock %}</title>
  <style>
    body { font-family: -apple-system, "Segoe UI", system-ui, sans-serif;
           max-width: 1000px; margin: 2rem auto; padding: 0 1rem;
           color: #1a1a1a; line-height: 1.5; }
    h1, h2, h3 { margin-top: 2.2rem; }
    h1 { border-bottom: 2px solid #333; padding-bottom: .35rem; }
    h2 { border-bottom: 1px solid #ccc; padding-bottom: .25rem; }
    table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
    th, td { border: 1px solid #d0d0d0; padding: .45rem .6rem; text-align: left; vertical-align: top; }
    th { background: #f4f4f4; }
    code, pre { font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
                background: #f5f5f5; padding: 1px 4px; border-radius: 3px; }
    pre { padding: .75rem; overflow-x: auto; }
    .sev { display: inline-block; padding: 1px 8px; border-radius: 3px;
           font-size: .8rem; font-weight: 600; color: #fff; }
    .sev-critical { background: #8b0000; }
    .sev-high     { background: #c92a2a; }
    .sev-medium   { background: #d9822b; }
    .sev-low      { background: #5c7cfa; }
    .sev-info     { background: #888; }
    .meta { color: #666; font-size: .9rem; }
    .summary-bar { display: flex; gap: .5rem; margin: 1rem 0; }
    .summary-bar > div { padding: .5rem .9rem; border-radius: 4px;
                         background: #f4f4f4; min-width: 5rem; text-align: center; }
    .summary-bar > div.crit { background: #fde0e0; }
    .summary-bar > div.high { background: #fde9d2; }
    .summary-bar > div.med  { background: #fff5d6; }
    .summary-bar > div.low  { background: #eaf0fd; }
    .summary-bar > div.info { background: #f0f0f0; }
    .ref { color: #666; font-family: ui-monospace, monospace; font-size: .85rem; }
  </style>
</head>
<body>
  {% block body %}{% endblock %}
  <hr>
  <p class="meta">Generated by AuditCore report-generator at {{ generated_at }}.
  Phase 1: manual renderer — no AI narrative.</p>
</body>
</html>
