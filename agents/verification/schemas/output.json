{
  "$id": "https://schemas.auditcore.dev/v1/agents/verification_output.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerificationAgentOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["tests"],
  "properties": {
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "name", "kind", "spec"],
        "properties": {
          "finding_id": { "type": "string", "format": "uuid" },
          "name":       { "type": "string", "maxLength": 120 },
          "kind":       { "enum": ["command","scan","metric_check","query"] },
          "spec":       { "type": "object" },
          "notes":      { "type": "string", "maxLength": 400 }
        }
      }
    }
  }
}
