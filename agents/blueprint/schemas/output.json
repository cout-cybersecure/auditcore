{
  "$id": "https://schemas.auditcore.dev/v1/agents/blueprint_output.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BlueprintAgentOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["domain", "target", "format", "artifact", "sources", "applies_to_assets"],
        "properties": {
          "domain":            { "enum": ["security","performance","cloud","k8s","db","hardware"] },
          "target":            { "type": "string", "maxLength": 120 },
          "format":            { "enum": ["terraform","helm","kustomize","ansible","sql","markdown","yaml"] },
          "artifact":          { "type": "string", "description": "raw artifact body" },
          "sources":           { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uuid" } },
          "applies_to_assets": { "type": "array", "items": { "type": "string", "format": "uuid" } },
          "idempotent":        { "type": "boolean", "default": true },
          "review_required":   { "type": "boolean", "default": true },
          "notes":             { "type": "string", "maxLength": 800 }
        }
      }
    }
  }
}
