{
  "$id": "https://schemas.auditcore.dev/v1/agents/domain_agent_output.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DomainAgentOutput",
  "description": "Standard output envelope for domain-analysis agents (security, performance, cloud, k8s, db, hardware). Findings MUST cite evidence_ids; recommendations MUST reference a finding_id from the same response.",
  "type": "object",
  "additionalProperties": false,
  "required": ["findings", "recommendations"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["temp_id", "asset_id", "title", "description", "severity", "evidence_ids"],
        "properties": {
          "temp_id":        { "type": "string", "description": "agent-local id; recommendations reference this" },
          "asset_id":       { "type": "string", "format": "uuid" },
          "title":          { "type": "string", "maxLength": 120 },
          "description":    { "type": "string", "maxLength": 4000 },
          "severity":       { "enum": ["info","low","medium","high","critical"] },
          "evidence_ids":   { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uuid" } },
          "cwe":            { "type": "array", "items": { "type": "string" }, "default": [] },
          "cve":            { "type": "array", "items": { "type": "string" }, "default": [] },
          "cis_controls":   { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_temp_id", "summary", "steps", "effort_estimate", "blast_radius", "rollback_plan"],
        "properties": {
          "finding_temp_id":         { "type": "string" },
          "summary":                 { "type": "string", "maxLength": 200 },
          "steps":                   { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "effort_estimate":         { "enum": ["minutes","hours","days","weeks"] },
          "blast_radius":            { "enum": ["isolated","service","tenant","global"] },
          "requires_change_window":  { "type": "boolean", "default": false },
          "automation_available":    { "type": "boolean", "default": false },
          "automation_ref":          { "type": ["string","null"] },
          "rollback_plan":           { "type": "string" }
        }
      }
    }
  }
}
