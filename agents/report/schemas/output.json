{
  "$id": "https://schemas.auditcore.dev/v1/agents/report_output.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReportAgentOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["audience", "order", "title", "body_md"],
        "properties": {
          "audience":            { "enum": ["executive","engineer"] },
          "order":               { "type": "integer", "minimum": 0 },
          "title":               { "type": "string", "maxLength": 200 },
          "body_md":             { "type": "string" },
          "embedded_findings":   { "type": "array", "items": { "type": "string", "format": "uuid" }, "default": [] },
          "embedded_blueprints": { "type": "array", "items": { "type": "string", "format": "uuid" }, "default": [] }
        }
      }
    }
  }
}
